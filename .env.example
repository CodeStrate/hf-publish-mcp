HF_TOKEN=hf_your_write_scoped_token_here

# Optional: override where jobs and archives are stored (default: ~/.hf_mcp)
# HF_MCP_DIR=/custom/path

# Optional: max completed jobs kept in the active file before archiving (default: 50)
# HF_MCP_MAX_COMPLETED_JOBS=50

# HF OAUTH for gguf-my-repo Space to be used by MCP
HF_OAUTH_CLIENT_ID=your_oauth_app_client_id
HF_OAUTH_CLIENT_SECRET=your_oauth_app_client_secret 
